{
  "version": 2,
  "builds": [
    {
      "src": "src/api.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**", "src/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/api.ts"
    },
    {
      "src": "/health",
      "dest": "src/api.ts"
    },
    {
      "src": "/(.+)", 
      "dest": "/public/$1"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ]
}